# ============================================================
# PROMPTFOO LLM PROVIDER CREDENTIALS
# ============================================================

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_ID=your-deployment-id

# Custom Bearer Token Endpoint
CUSTOM_ENDPOINT_URL=https://your-api-endpoint.com/v1/completions
CUSTOM_BEARER_TOKEN=your-bearer-token-here

# OpenRouter (fallback/comparison)
OPENROUTER_API_KEY=your-openrouter-key-here

# Local/Self-hosted (Ollama, vLLM)
LOCAL_MODEL_ENDPOINT=http://localhost:11434

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Database type: mysql2, postgres, or sqlite
DB_TYPE=mysql2

# MySQL Configuration (AWS RDS or local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=evals_db

# PostgreSQL Configuration (alternative)
# DATABASE_URL=postgresql://user:password@localhost:5432/evals_db

# SQLite Configuration (alternative for local dev)
# DATABASE_URL=sqlite.db

# ============================================================
# API & AUTHENTICATION
# ============================================================

# API Server Port
API_PORT=3000

# JWT Secret Key (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-here

# Basic Auth for local development
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=admin123

# ============================================================
# EVALUATION CONFIGURATION
# ============================================================

# Disable remote generation for offline testing
# PROMPTFOO_DISABLE_REMOTE_GENERATION=true

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Cache settings
CACHE_ENABLED=true
CACHE_DIR=~/.cache/promptfoo

# ============================================================
# NOTIONAL FUTURE ADDITIONS
# ============================================================

# Multi-tenant support (future)
# ENABLE_MULTI_TENANT=false

# OAuth2 (future)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# Slack notifications (future)
# SLACK_WEBHOOK_URL=

# Email notifications (future)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
